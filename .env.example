# Copy to .env and fill in real values. .env is gitignored.

# --- Django ---
# DJANGO_SETTINGS_MODULE lo fija docker-compose.yml (prod) o manage.py (dev por defecto).
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_HOSTS=edvardks.com,www.edvardks.com

# --- SMTP (contact form) ---
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
MAIL_USERNAME=you@example.com
MAIL_PASSWORD=app-password-here
