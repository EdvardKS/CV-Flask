# Copy to .env and fill in real values. .env is gitignored.

# --- Email (formulario de contacto, /api/contact) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-app-password
CONTACT_RECIPIENT=you@example.com

# --- Ollama (chat IA, /api/ai/chat) ---
# Docker network: http://<service-name>:11434
# Host local:     http://host.docker.internal:11434
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=phi3:mini

# --- News feed (aside derecha) ---
NEWS_GITHUB_USER=EdvardKS
NEWS_LINKEDIN_URL=https://www.linkedin.com/in/edvardks/
NEWS_TTL_MS=1800000

# --- Padel (CSVs por jugador) ---
PADEL_DATA_DIR=/app/public/padel-data
